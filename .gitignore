# =============================================================
#  Shree Abhinandan Product — repo .gitignore
# =============================================================

# Dependencies
node_modules/
.pnp
.pnp.js

# Build artifacts
dist/
build/
.next/
*.tsbuildinfo
tsconfig.tsbuildinfo
next-env.d.ts

# Env / secrets — NEVER commit
.env
.env.local
.env.*.local
.env.development
.env.production
!.env.example

# User uploads — runtime folder where the app writes files, NOT the
# source directory. The bare `uploads/` rule used to match everything
# including `backend/src/uploads/` (the module folder), which silently
# excluded that source code from the repo → deploy failed. Anchor the
# rules to the specific runtime paths only.
/backend/uploads/
/uploads/

# DB backups
backups/
*.sql.gz
*.dump

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Prisma
# Migrations ARE checked in; generated client is not.
backend/node_modules/.prisma/

# Vercel
.vercel/

# Test outputs
coverage/

# Misc
*.tmp
*.bak

# Video / screencast files — not source
*.mp4
*.mov
*.webm

# Legacy data export (SilverERP migration source) — 71 MB, not needed at runtime
SilverERP_Export/

# Claude Code / assistant session metadata — local per-machine, not shared
.claude/
