# =============================================================
#  Shree Abhinandan Product — backend env
#  Copy to .env for local dev. Railway sets these via the dashboard
#  (Settings → Variables) in production.
# =============================================================

# ---------------- Database (Postgres) ----------------
# Local dev: Postgres running on your machine (Docker or installed).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/abhinandan_erp"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/abhinandan_erp"

# Railway production: attach a Postgres service to the project. Railway
# auto-injects DATABASE_URL — no need to set it manually. Prisma reads
# both DATABASE_URL and DIRECT_URL; on Railway they can be the same.
# DIRECT_URL="${{Postgres.DATABASE_URL}}"

# ---------------- Server ----------------
# Railway sets PORT automatically — don't hardcode in prod.
PORT=4000

# Comma-separated allowed origins for CORS (frontend URLs).
# Include local dev + your Vercel deploy URL (and any preview URLs).
CORS_ORIGIN="http://localhost:3000,https://your-app.vercel.app"

# ---------------- JWT ----------------
# In production: `openssl rand -base64 48` for a strong secret.
JWT_SECRET="change-this-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# ---------------- File uploads ----------------
# Local dev: writes to backend/uploads/.
# Railway production: mount a persistent volume at /app/uploads and set
# UPLOAD_DIR=/app/uploads so writes survive redeploys.
UPLOAD_DIR="uploads"
MAX_UPLOAD_MB=5
