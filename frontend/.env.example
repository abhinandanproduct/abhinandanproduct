# =============================================================
#  Shree Abhinandan Product — frontend env
#  Copy to .env.local for local dev. Vercel sets these via the
#  dashboard (Settings → Environment Variables) in production.
# =============================================================

# The NestJS API base URL (must include /api trailing path).
# Local dev: http://localhost:4000/api
# Vercel production: https://<your-railway-service>.up.railway.app/api
NEXT_PUBLIC_API_URL="http://localhost:4000/api"

# Root URL of the API (no /api suffix) — used to build absolute paths
# to /uploads/... for images. Same host as API_URL, minus /api.
NEXT_PUBLIC_FILE_BASE="http://localhost:4000"
